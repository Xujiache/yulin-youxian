<view class="detail-page">
  <skeleton wx:if="{{loading}}" type="detail" />
  <view class="detail-header">
    <view class="back" bindtap="handleBack">
      <image class="back-icon" src="/assets/icons/back-green.svg" mode="aspectFit" />
    </view>
    <text class="title">商品详情</text>
    <text class="share">分享</text>
  </view>

  <image class="product-hero" src="{{product.image}}" mode="aspectFill" />

  <view class="info card">
    <view class="name-row">
      <text class="name">{{product.name}}</text>
      <text wx:if="{{product.badge}}" class="badge">{{product.badge}}</text>
    </view>
    <text class="subtitle">{{product.subtitle}}</text>
    <view class="price-row">
      <text class="price">￥{{amountText}}</text>
      <text class="unit">当前小计</text>
    </view>
    <text class="stock">库存充足，约 {{product.stockQty}}{{product.saleUnit}}</text>
  </view>

  <view class="buy-card card">
    <view class="buy-head">
      <view class="buy-copy">
        <text class="buy-title">购买数量</text>
        <text class="buy-tip">{{product.minPurchaseQty}}{{product.saleUnit}} 起购，每次增加 {{product.stepQty}}{{product.saleUnit}}</text>
      </view>
      <text class="buy-current">已选 {{quantity}}{{product.saleUnit}}</text>
    </view>
    <view class="buy-stepper-row">
      <quantity-stepper
        class="buy-stepper"
        value="{{quantity}}"
        min="{{product.minPurchaseQty}}"
        max="{{product.stockQty}}"
        step="{{product.stepQty}}"
        unit="{{product.saleUnit}}"
        bind:change="handleQuantityChange"
      />
    </view>
  </view>

  <view class="desc card">
    <text class="desc-title">商品详情</text>
    <text class="desc-text">产地直采，新鲜到店。生鲜产品受季节、气候等因素影响，外观及口感可能略有差异，请以实物为准。</text>
  </view>

  <view class="detail-footer">
    <button class="ghost-button" bindtap="handleAddCart">加入购物车</button>
    <button class="primary-button" bindtap="handleBuyNow">立即购买</button>
  </view>
</view>
