.detail-page {
  min-height: 100vh;
  padding: 176rpx 22rpx 148rpx;
  background: #f5f6f7;
}

.detail-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 176rpx;
  padding: 88rpx 24rpx 0;
  box-sizing: border-box;
  background: #f5f6f7;
  box-shadow: 0 1rpx 0 rgba(16, 24, 21, 0.04);
}

.back,
.share {
  color: #007a3d;
  font-size: 28rpx;
}

.back {
  position: absolute;
  left: 24rpx;
  bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  min-width: 0;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  z-index: 1;
  background: #e8f7ee;
  border: 0;
  border-radius: 999rpx;
  line-height: 1;
}

.back::after {
  border: 0;
}

.back-icon {
  width: 32rpx;
  height: 32rpx;
}

.title {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  max-width: 320rpx;
  color: #101815;
  font-size: 32rpx;
  font-weight: 700;
}

.share {
  position: absolute;
  right: 176rpx;
  bottom: 20rpx;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 72rpx;
  height: 48rpx;
  color: #007a3d;
  font-size: 24rpx;
  font-weight: 600;
  background: #e8f7ee;
  border-radius: 999rpx;
}

.product-hero {
  width: 100%;
  height: 560rpx;
  background: #eef3ef;
  border-radius: 0 0 34rpx 34rpx;
  box-shadow: 0 12rpx 30rpx rgba(8, 34, 20, 0.06);
}

.info,
.buy-card,
.desc {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 26rpx;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.name {
  color: #101815;
  font-size: 40rpx;
  font-weight: 800;
}

.badge {
  padding: 5rpx 12rpx;
  color: #1e5b2b;
  font-size: 22rpx;
  background: #e8f4df;
  border-radius: 8rpx;
}

.subtitle,
.stock,
.buy-tip,
.desc-text {
  display: block;
  margin-top: 12rpx;
  color: #5f6b64;
  font-size: 26rpx;
  line-height: 40rpx;
}

.price-row {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  margin-top: 22rpx;
}

.price {
  color: #007a3d;
  font-size: 58rpx;
  font-weight: 800;
}

.unit {
  padding-bottom: 8rpx;
  color: #5f6b64;
  font-size: 24rpx;
}

.buy-card {
  display: block;
}

.buy-title,
.desc-title {
  display: block;
  color: #101815;
  font-size: 32rpx;
  font-weight: 700;
}

.buy-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.buy-copy {
  flex: 1;
  min-width: 0;
}

.buy-current {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  color: #007a3d;
  font-size: 24rpx;
  font-weight: 700;
  background: #e8f7ee;
  border-radius: 999rpx;
}

.buy-stepper-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 24rpx;
}

.buy-stepper {
  width: 232rpx;
}

.detail-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 80;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 20rpx 24rpx 34rpx;
  background: #ffffff;
  box-shadow: 0 -10rpx 32rpx rgba(10, 34, 22, 0.1);
}
