<view class="login-page">
  <skeleton wx:if="{{loading}}" type="form" />
  <view class="login-hero">
    <image class="hero-image" src="{{brandImage}}" mode="aspectFill" />
    <view class="login-nav">
      <image class="back-icon" src="/assets/icons/back-green.svg" mode="aspectFit" bindtap="goBack" />
      <text class="skip-text" bindtap="goBack">暂时跳过</text>
    </view>
  </view>

  <view class="login-sheet">
    <view class="login-copy">
      <text class="login-title">微信快捷登录</text>
      <text class="login-desc">登录后可同步订单、地址、购物车和售后进度</text>
    </view>

    <view class="login-button-wrap">
      <button class="login-button" loading="{{submitting}}" bindtap="handleLogin">
        {{submitting ? '登录中' : '微信一键登录'}}
      </button>
      <text class="recommend-badge">推荐使用</text>
    </view>

    <view class="agreement-row">
      <view class="agree-circle"></view>
      <text class="agreement-text">登录即表示同意微信授权并使用禹邻优鲜服务</text>
    </view>
  </view>
</view>
