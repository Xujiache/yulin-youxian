.login-page {
  min-height: 100vh;
  padding: 176rpx 24rpx 52rpx;
  box-sizing: border-box;
  background: #f5f7f6;
}

.login-header {
  justify-content: center;
  padding-right: 28rpx;
}

.back-icon {
  position: absolute;
  left: 28rpx;
  width: 44rpx;
  height: 44rpx;
}

.centered-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.login-panel {
  display: flex;
  flex-direction: column;
}

.brand-area {
  position: relative;
  height: 316rpx;
  overflow: hidden;
  border-radius: var(--radius-panel);
  box-shadow: 0 14rpx 34rpx rgba(13, 35, 24, 0.08);
}

.brand-image,
.brand-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.brand-mask {
  background:
    linear-gradient(180deg, rgba(0, 0, 0, 0.04), rgba(0, 0, 0, 0.2)),
    linear-gradient(90deg, rgba(5, 43, 25, 0.74), rgba(5, 78, 38, 0.14));
}

.brand-copy {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  height: 100%;
  gap: 12rpx;
  padding: 42rpx 34rpx;
  box-sizing: border-box;
  color: #ffffff;
}

.brand-title {
  font-size: 44rpx;
  font-weight: 900;
  line-height: 56rpx;
}

.brand-subtitle {
  max-width: 560rpx;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 38rpx;
  opacity: 0.94;
}

.form-card {
  position: relative;
  z-index: 2;
  margin-top: -28rpx;
  padding: 36rpx 30rpx 34rpx;
  box-sizing: border-box;
  background: #ffffff;
  border-radius: var(--radius-panel);
  box-shadow: 0 18rpx 46rpx rgba(13, 35, 24, 0.08);
}

.card-head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.login-title {
  color: #101815;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.login-desc {
  color: #68766d;
  font-size: 25rpx;
  font-weight: 500;
  line-height: 38rpx;
}

.auth-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 30rpx;
  padding-top: 24rpx;
  box-sizing: border-box;
  border-top: 2rpx solid #eef3f0;
}

.auth-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  color: #34443a;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 34rpx;
}

.auth-dot {
  flex: 0 0 auto;
  width: 12rpx;
  height: 12rpx;
  margin-top: 11rpx;
  background: #008a45;
  border-radius: var(--radius-pill);
}

.login-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 92rpx;
  margin-top: 34rpx;
  box-sizing: border-box;
  color: #ffffff;
  line-height: normal;
  font-size: 29rpx;
  font-weight: 900;
  background: #008a45;
  border-radius: var(--radius-pill);
  box-shadow: 0 14rpx 28rpx rgba(0, 122, 61, 0.18);
}

.login-button::after {
  border: 0;
}

.login-policy {
  display: block;
  margin-top: 20rpx;
  color: #8a958e;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 32rpx;
  text-align: center;
}
