.login-page {
  position: relative;
  height: 100vh;
  min-height: 100vh;
  overflow: hidden;
  background: #ffffff;
}

.login-hero {
  position: relative;
  height: 78vh;
  overflow: hidden;
  background: #10a8f5;
}

.hero-image {
  display: block;
  width: 100%;
  height: 100%;
}

.login-nav {
  position: absolute;
  top: 92rpx;
  right: 176rpx;
  left: 24rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-icon {
  width: 44rpx;
  height: 44rpx;
  padding: 12rpx;
  background: rgba(255, 255, 255, 0.86);
  border-radius: var(--radius-pill);
}

.skip-text {
  padding: 8rpx 18rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 27rpx;
  font-weight: 800;
  line-height: 40rpx;
  background: rgba(0, 122, 61, 0.12);
  border-radius: var(--radius-pill);
  text-shadow: 0 2rpx 8rpx rgba(0, 85, 145, 0.16);
}

.login-sheet {
  position: absolute;
  right: 0;
  bottom: -42rpx;
  left: 0;
  z-index: 3;
  min-height: 31vh;
  padding: 52rpx 56rpx calc(66rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #ffffff;
  border-radius: 48rpx 48rpx 0 0;
  box-shadow: 0 -20rpx 44rpx rgba(12, 43, 27, 0.08);
}

.login-copy {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.login-title {
  color: #101815;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 48rpx;
  text-align: center;
}

.login-desc {
  color: #9aa4a0;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 30rpx;
  text-align: center;
}

.login-button-wrap {
  position: relative;
  margin-top: 28rpx;
}

.login-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 78rpx;
  box-sizing: border-box;
  color: #103522;
  line-height: normal;
  font-size: 27rpx;
  font-weight: 900;
  background: #64dda0;
  border-radius: var(--radius-pill);
}

.login-button::after {
  border: 0;
}

.recommend-badge {
  position: absolute;
  top: -16rpx;
  right: 0;
  z-index: 2;
  padding: 6rpx 16rpx;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 26rpx;
  background: #263044;
  border-radius: 8rpx;
}

.agreement-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 18rpx;
}

.agree-circle {
  flex: 0 0 auto;
  width: 26rpx;
  height: 26rpx;
  margin-top: 1rpx;
  box-sizing: border-box;
  background: #ffffff;
  border: 3rpx solid #d8dedb;
  border-radius: var(--radius-pill);
}

.agree-circle.checked {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #008a45;
  border-color: #008a45;
}

.agree-check {
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 24rpx;
}

.agreement-copy {
  flex: 1;
  min-width: 0;
  color: #929b97;
  font-size: 21rpx;
  font-weight: 500;
  line-height: 30rpx;
}

.agreement-link {
  color: #008a45;
  font-weight: 700;
}
