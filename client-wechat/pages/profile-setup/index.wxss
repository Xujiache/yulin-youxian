.setup-page {
  min-height: 100vh;
  padding: 0 22rpx 52rpx;
  background: #f5f6f7;
}

.setup-hero {
  position: relative;
  height: 330rpx;
  margin: 0 -22rpx;
  overflow: hidden;
}

.setup-bg,
.setup-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.setup-mask {
  background: linear-gradient(90deg, rgba(8, 33, 20, 0.68), rgba(6, 80, 38, 0.12));
}

.setup-copy {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  height: 100%;
  gap: 12rpx;
  padding: 120rpx 34rpx 42rpx;
  color: #ffffff;
}

.setup-title {
  font-size: 42rpx;
  font-weight: 900;
}

.setup-subtitle {
  max-width: 560rpx;
  font-size: 25rpx;
  line-height: 36rpx;
}

.setup-card {
  margin-top: 24rpx;
  padding: 34rpx 28rpx;
  background: #ffffff;
  border-radius: var(--radius-panel);
  box-shadow: 0 10rpx 28rpx rgba(8, 34, 20, 0.06);
}

.avatar-button {
  display: flex;
  align-items: center;
  gap: 22rpx;
  color: #007a3d;
  font-size: 26rpx;
  font-weight: 800;
}

.avatar-preview {
  width: 112rpx;
  height: 112rpx;
  border: 6rpx solid #e8f6ed;
  border-radius: var(--radius-pill);
}

.field {
  margin-top: 34rpx;
}

.field-label {
  display: block;
  color: #1b2520;
  font-size: 26rpx;
  font-weight: 800;
}

.field-input {
  height: 82rpx;
  margin-top: 14rpx;
  padding: 0 22rpx;
  color: #101815;
  font-size: 28rpx;
  background: #f7faf8;
  border: 2rpx solid #edf1ee;
  border-radius: var(--radius-card);
}

.submit-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  margin-top: 34rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  background: #008a45;
  border-radius: var(--radius-pill);
  box-shadow: 0 12rpx 26rpx rgba(0, 122, 61, 0.2);
}
