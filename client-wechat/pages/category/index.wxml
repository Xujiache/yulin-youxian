<view class="category-page">
  <skeleton wx:if="{{loading}}" type="category" has-tabbar="{{true}}" />
  <view class="page-header">
    <text class="page-title">禹邻优鲜</text>
    <text class="header-action" bindtap="openFilter">筛选</text>
  </view>

  <view class="search-area">
    <view class="search-card" bindtap="goSearch">
      <image class="search-icon" src="/assets/icons/search.svg" mode="aspectFit" />
      <text class="search-placeholder">搜索新鲜蔬菜、水果、肉类</text>
    </view>
  </view>

  <view class="category-layout">
    <scroll-view class="sidebar" scroll-y>
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-item {{activeCategoryId === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="handleCategory"
      >
        {{item.name}}
      </view>
    </scroll-view>

    <scroll-view class="product-panel" scroll-y>
      <view class="panel-head">
        <text>共 {{products.length}} 件商品</text>
        <text>{{activeFilterText}}</text>
      </view>

      <view wx:if="{{products.length}}" class="product-grid">
        <product-card
          wx:for="{{products}}"
          wx:key="id"
          product="{{item}}"
          bind:add="handleAdd"
        />
      </view>

      <view wx:else class="empty-state">
        <image class="empty-icon" src="/assets/icons/search.svg" mode="aspectFit" />
        <text class="empty-title">没有符合条件的商品</text>
        <text class="empty-subtitle">换个分类或重置筛选条件</text>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{filterVisible}}" class="filter-mask" catchtap="closeFilter">
    <view class="filter-panel" catchtap="noop">
      <view class="filter-head">
        <text>筛选商品</text>
        <text class="filter-close" catchtap="closeFilter">关闭</text>
      </view>

      <view class="filter-section">
        <text class="filter-title">排序方式</text>
        <view class="chip-grid">
          <view
            wx:for="{{sortOptions}}"
            wx:key="value"
            class="filter-chip {{sortMode === item.value ? 'active' : ''}}"
            data-value="{{item.value}}"
            catchtap="chooseSort"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="filter-section">
        <text class="filter-title">价格区间</text>
        <view class="chip-grid">
          <view
            wx:for="{{priceOptions}}"
            wx:key="value"
            class="filter-chip {{priceRange === item.value ? 'active' : ''}}"
            data-value="{{item.value}}"
            catchtap="choosePrice"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="stock-row">
        <view>
          <text class="filter-title">只看有货</text>
          <text class="stock-tip">库存为 0 的商品将隐藏</text>
        </view>
        <switch checked="{{onlyStock}}" color="#008a45" bindchange="handleStockChange" />
      </view>

      <view class="filter-actions">
        <button class="reset-button" catchtap="resetFilter">重置</button>
        <button class="done-button" catchtap="closeFilter">完成</button>
      </view>
    </view>
  </view>

  <cart-add-sheet
    visible="{{sheetVisible}}"
    product="{{selectedProduct}}"
    bind:close="handleCloseSheet"
    bind:confirm="handleConfirmAdd"
  />
  <app-tabbar active="category" cart-count="{{cartCount}}" />
</view>
