.category-page {
  min-height: 100vh;
  background: #f5f6f7;
  padding-top: 176rpx;
}

.header-action {
  color: #007a3d;
  font-size: 26rpx;
}

.search-area {
  position: fixed;
  top: 176rpx;
  left: 0;
  right: 0;
  z-index: 40;
  padding: 0 22rpx 18rpx;
  background: #f5f6f7;
}

.search-card {
  display: flex;
  align-items: center;
  height: 78rpx;
  padding: 7rpx 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbfdfb 100%);
  border: 2rpx solid rgba(0, 122, 61, 0.12);
  border-radius: 999rpx;
  box-shadow: 0 12rpx 30rpx rgba(10, 39, 22, 0.08);
}

.search-icon {
  flex-shrink: 0;
  width: 32rpx;
  height: 32rpx;
}

.search-input,
.search-placeholder {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  padding-left: 16rpx;
  font-size: 24rpx;
}

.search-placeholder {
  display: flex;
  align-items: center;
  color: #8a9690;
}

.category-layout {
  position: fixed;
  top: 274rpx;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  background: #f5f6f7;
}

.sidebar {
  width: 168rpx;
  height: 100%;
  padding-bottom: 160rpx;
  background: #eef1f2;
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 112rpx;
  padding: 0 12rpx;
  color: #4e5b53;
  font-size: 26rpx;
  border-left: 6rpx solid transparent;
}

.category-item.active {
  color: #007a3d;
  font-weight: 700;
  background: #ffffff;
  border-left-color: #007a3d;
}

.product-panel {
  flex: 1;
  height: 100%;
  padding: 16rpx 14rpx 182rpx;
  background: #ffffff;
}

.panel-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 2rpx;
  color: #5b665f;
  font-size: 22rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 118rpx 18rpx 0;
  padding: 48rpx 22rpx;
  background: #f8faf9;
  border-radius: 26rpx;
}

.empty-icon {
  width: 70rpx;
  height: 70rpx;
  opacity: 0.55;
}

.empty-title {
  margin-top: 20rpx;
  color: #101815;
  font-size: 28rpx;
  font-weight: 800;
}

.empty-subtitle {
  margin-top: 10rpx;
  color: #7b8781;
  font-size: 23rpx;
}

.filter-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 200;
  display: flex;
  align-items: flex-end;
  background: rgba(16, 24, 21, 0.42);
}

.filter-panel {
  width: 100%;
  padding: 30rpx 28rpx calc(30rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-radius: 34rpx 34rpx 0 0;
}

.filter-head,
.filter-actions,
.stock-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.filter-head {
  color: #101815;
  font-size: 32rpx;
  font-weight: 800;
}

.filter-close {
  color: #007a3d;
  font-size: 24rpx;
  font-weight: 600;
}

.filter-section {
  margin-top: 28rpx;
}

.filter-title {
  display: block;
  color: #101815;
  font-size: 26rpx;
  font-weight: 700;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.filter-chip {
  padding: 16rpx 24rpx;
  color: #53645c;
  font-size: 24rpx;
  background: #f4f6f5;
  border: 2rpx solid transparent;
  border-radius: 999rpx;
}

.filter-chip.active {
  color: #007a3d;
  font-weight: 700;
  background: #e8f6ed;
  border-color: rgba(0, 122, 61, 0.28);
}

.stock-row {
  margin-top: 30rpx;
  padding: 22rpx 0;
  border-top: 2rpx solid #eef1ef;
}

.stock-tip {
  display: block;
  margin-top: 8rpx;
  color: #7b8781;
  font-size: 22rpx;
}

.filter-actions {
  gap: 18rpx;
  margin-top: 18rpx;
}

.reset-button,
.done-button {
  flex: 1;
  height: 78rpx;
  padding: 0;
  font-size: 26rpx;
  font-weight: 800;
  border-radius: 999rpx;
}

.reset-button {
  color: #007a3d;
  background: #ffffff;
  border: 2rpx solid rgba(0, 122, 61, 0.5);
}

.done-button {
  color: #ffffff;
  background: #008a45;
  box-shadow: 0 10rpx 22rpx rgba(0, 122, 61, 0.18);
}
