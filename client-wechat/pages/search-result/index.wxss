.result-page {
  min-height: 100vh;
  padding: 176rpx 24rpx 48rpx;
  background: #f5f6f7;
}

.back-icon {
  width: 44rpx;
  height: 44rpx;
}

.filter-link {
  color: #007a3d;
  font-size: 26rpx;
  font-weight: 700;
}

.search-row {
  margin-top: 18rpx;
}

.search-card {
  display: flex;
  align-items: center;
  height: 78rpx;
  padding: 8rpx 9rpx 8rpx 24rpx;
  background: #ffffff;
  border: 2rpx solid rgba(0, 122, 61, 0.12);
  border-radius: 999rpx;
  box-shadow: 0 12rpx 30rpx rgba(10, 39, 22, 0.08);
}

.search-icon {
  flex-shrink: 0;
  width: 32rpx;
  height: 32rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 58rpx;
  padding: 0 14rpx;
  color: #101815;
  font-size: 24rpx;
}

.search-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 25%;
  min-width: 132rpx;
  max-width: 156rpx;
  height: 54rpx;
  padding: 0;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 700;
  background: #008a45;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 18rpx rgba(0, 122, 61, 0.18);
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 28rpx 2rpx 18rpx;
  color: #5b665f;
  font-size: 24rpx;
}

.result-page .summary-row {
  display: none;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  padding-bottom: 40rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 150rpx;
  padding: 58rpx 30rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 10rpx 28rpx rgba(8, 34, 20, 0.04);
}

.empty-icon {
  width: 76rpx;
  height: 76rpx;
  opacity: 0.6;
}

.empty-title {
  margin-top: 22rpx;
  color: #101815;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-subtitle {
  margin-top: 12rpx;
  color: #7b8781;
  font-size: 24rpx;
}

.filter-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 200;
  display: flex;
  align-items: flex-end;
  background: rgba(16, 24, 21, 0.42);
}

.filter-panel {
  width: 100%;
  padding: 30rpx 28rpx 0;
  background: #ffffff;
  border-radius: var(--radius-card) var(--radius-card) 0 0;
}

.filter-head,
.filter-actions,
.stock-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.filter-head {
  color: #101815;
  font-size: 32rpx;
  font-weight: 800;
}

.filter-close {
  color: #007a3d;
  font-size: 24rpx;
  font-weight: 600;
}

.filter-section {
  margin-top: 28rpx;
}

.filter-title {
  display: block;
  color: #101815;
  font-size: 26rpx;
  font-weight: 700;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.filter-chip {
  padding: 16rpx 24rpx;
  color: #53645c;
  font-size: 24rpx;
  background: #f4f6f5;
  border: 2rpx solid transparent;
  border-radius: 999rpx;
}

.filter-chip.active {
  color: #007a3d;
  font-weight: 700;
  background: #e8f6ed;
  border-color: rgba(0, 122, 61, 0.28);
}

.stock-row {
  margin-top: 30rpx;
  padding: 22rpx 0;
  border-top: 2rpx solid #eef1ef;
}

.stock-tip {
  display: block;
  margin-top: 8rpx;
  color: #7b8781;
  font-size: 22rpx;
}

.filter-actions {
  gap: 20rpx;
  margin: 24rpx -28rpx 0;
  padding: 20rpx 28rpx calc(22rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 2rpx solid #eef1ef;
  box-shadow: 0 -10rpx 28rpx rgba(19, 41, 28, 0.05);
}

.reset-button,
.done-button {
  flex: 1;
  height: 76rpx;
  padding: 0;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 76rpx;
  border-radius: 22rpx;
}

.reset-button {
  color: #007a3d;
  background: #ffffff;
  border: 2rpx solid rgba(0, 122, 61, 0.42);
}

.done-button {
  color: #ffffff;
  background: #008a45;
  box-shadow: 0 10rpx 22rpx rgba(0, 122, 61, 0.18);
}

.reset-button::after,
.done-button::after {
  border: 0;
}
