.home-page {
  padding: 188rpx 22rpx 164rpx;
  background: linear-gradient(180deg, #edf8f1 0%, #f5f6f7 360rpx, #f5f6f7 100%);
}

.brand {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #007a3d 0%, #16a65a 100%);
  border-radius: 18rpx;
  box-shadow: 0 12rpx 24rpx rgba(0, 122, 61, 0.2);
}

.brand-copy {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.brand-subtitle {
  color: #66736b;
  font-size: 22rpx;
  line-height: 28rpx;
}

.home-stage {
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(0, 122, 61, 0.08);
  border-radius: 32rpx;
  box-shadow: 0 18rpx 44rpx rgba(8, 34, 20, 0.07);
}

.search-card {
  display: flex;
  align-items: center;
  height: 78rpx;
  padding: 8rpx 9rpx 8rpx 24rpx;
  background: #ffffff;
  border: 2rpx solid rgba(0, 122, 61, 0.12);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 24rpx rgba(10, 39, 22, 0.06);
}

.search-icon {
  flex-shrink: 0;
  width: 32rpx;
  height: 32rpx;
}

.search-input,
.search-placeholder {
  flex: 1;
  min-width: 0;
  height: 58rpx;
  padding: 0 13rpx;
  color: #101815;
  font-size: 24rpx;
}

.search-placeholder {
  display: flex;
  align-items: center;
  color: #8a9690;
}

.search-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 112rpx;
  min-width: 112rpx;
  max-width: 112rpx;
  height: 54rpx;
  padding: 0;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #007a3d 0%, #15964f 100%);
  border-radius: 999rpx;
  box-shadow: 0 7rpx 16rpx rgba(0, 122, 61, 0.17);
}

.service-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin: 18rpx 0;
}

.service-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 46rpx;
  color: #267242;
  font-size: 22rpx;
  font-weight: 600;
  background: #eef9f2;
  border-radius: 999rpx;
}

.service-dot {
  width: 8rpx;
  height: 8rpx;
  background: #00a957;
  border-radius: 999rpx;
}

.hero-swiper {
  height: 300rpx;
  border-radius: 26rpx;
  overflow: hidden;
}

.hero {
  position: relative;
  height: 300rpx;
  overflow: hidden;
  border-radius: 26rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  gap: 7rpx;
  padding: 48rpx 30rpx 30rpx;
  color: #ffffff;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 60, 32, 0.78));
}

.hero-kicker {
  align-self: flex-start;
  padding: 6rpx 14rpx;
  color: #e9fff1;
  font-size: 21rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 999rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 800;
}

.hero-subtitle {
  font-size: 24rpx;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
  margin-top: 24rpx;
  padding: 24rpx 12rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 122, 61, 0.04);
  border-radius: 30rpx;
  box-shadow: 0 14rpx 34rpx rgba(8, 34, 20, 0.05);
}

.category-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  color: #101815;
  font-size: 22rpx;
}

.category-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  color: #007a3d;
  background: linear-gradient(180deg, #f2fbf5 0%, #ddf3e5 100%);
  border-radius: 999rpx;
}

.category-icon-image {
  width: 48rpx;
  height: 48rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 34rpx 2rpx 18rpx;
}

.section-title {
  display: block;
  color: #101815;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 44rpx;
}

.section-subtitle {
  display: block;
  margin-top: 4rpx;
  color: #7b8781;
  font-size: 22rpx;
  line-height: 30rpx;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 2rpx;
  color: #007a3d;
  font-size: 24rpx;
}

.section-more-icon {
  width: 24rpx;
  height: 24rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}
