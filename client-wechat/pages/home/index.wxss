.home-page {
  padding: 188rpx 22rpx 164rpx;
  background: #f5f6f7;
}

.brand {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.brand-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  background: #007a3d;
  border-radius: 14rpx;
}

.brand-copy {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.brand-subtitle {
  color: #7b8781;
  font-size: 22rpx;
  line-height: 28rpx;
}

.search-card {
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 7rpx 8rpx 7rpx 22rpx;
  background: #ffffff;
  border: 1rpx solid #e7ece9;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 20rpx rgba(8, 34, 20, 0.04);
}

.search-icon {
  flex-shrink: 0;
  width: 32rpx;
  height: 32rpx;
}

.search-input,
.search-placeholder {
  flex: 1;
  min-width: 0;
  height: 58rpx;
  padding: 0 13rpx;
  color: #101815;
  font-size: 24rpx;
}

.search-placeholder {
  display: flex;
  align-items: center;
  color: #8a9690;
}

.search-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 104rpx;
  min-width: 104rpx;
  max-width: 104rpx;
  height: 52rpx;
  padding: 0;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  background: #007a3d;
  border-radius: 999rpx;
}

.hero-swiper {
  height: 286rpx;
  margin-top: 22rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.hero {
  position: relative;
  height: 286rpx;
  overflow: hidden;
  background: #ffffff;
  border-radius: 20rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-copy {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 72rpx 28rpx 26rpx;
  color: #ffffff;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 48, 28, 0.66));
}

.hero-title {
  font-size: 38rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  line-height: 34rpx;
}

.category-grid {
  display: flex;
  align-items: stretch;
  justify-content: space-evenly;
  gap: 6rpx;
  margin-top: 22rpx;
  padding: 18rpx 10rpx 16rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbfefc 100%);
  border: 1rpx solid #edf3ef;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 26rpx rgba(8, 34, 20, 0.05);
}

.category-entry {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  padding: 2rpx 4rpx;
  color: #101815;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 30rpx;
}

.category-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 74rpx;
  height: 74rpx;
  color: #007a3d;
  background: linear-gradient(145deg, #f0fbf4 0%, #e1f4e9 100%);
  border: 1rpx solid rgba(0, 122, 61, 0.06);
  border-radius: 999rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), 0 8rpx 16rpx rgba(0, 122, 61, 0.08);
}

.category-icon-image {
  width: 42rpx;
  height: 42rpx;
}

.category-entry:active .category-icon {
  transform: scale(0.94);
}

.category-entry text {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.glass-mode .category-grid {
  background: rgba(255, 255, 255, 0.62);
  border-color: rgba(255, 255, 255, 0.82);
  box-shadow: 0 14rpx 30rpx rgba(25, 73, 47, 0.1), inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(var(--glass-blur)) saturate(140%);
  -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(140%);
}

.glass-mode .category-icon {
  background: rgba(228, 248, 236, 0.72);
  border-color: rgba(255, 255, 255, 0.76);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.82), 0 8rpx 16rpx rgba(25, 73, 47, 0.08);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 32rpx 2rpx 18rpx;
}

.section-title {
  display: block;
  color: #101815;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 42rpx;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 2rpx;
  color: #007a3d;
  font-size: 24rpx;
}

.section-more-icon {
  width: 24rpx;
  height: 24rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}
