<view class="page home-page">
  <skeleton wx:if="{{loading}}" type="home" has-tabbar="{{true}}" />
  <view class="page-header">
    <view class="brand">
      <view class="brand-mark">禹</view>
      <view class="brand-copy">
        <text class="page-title">禹邻优鲜</text>
        <text class="brand-subtitle">鲜达生鲜 · 门店配送</text>
      </view>
    </view>
  </view>

  <view class="home-stage">
    <view class="search-card" bindtap="goSearch">
      <image class="search-icon" src="/assets/icons/search.svg" mode="aspectFit" />
      <text class="search-placeholder">搜索蔬菜、水果、生鲜商品</text>
      <button class="search-button" catchtap="goSearch">搜索</button>
    </view>

    <view class="service-strip">
      <view class="service-item">
        <text class="service-dot"></text>
        <text>门店自配</text>
      </view>
      <view class="service-item">
        <text class="service-dot"></text>
        <text>预约送达</text>
      </view>
      <view class="service-item">
        <text class="service-dot"></text>
        <text>微信支付</text>
      </view>
    </view>

    <swiper
      class="hero-swiper"
      indicator-dots="{{banners.length > 1}}"
      autoplay="{{banners.length > 1}}"
      circular="{{banners.length > 1}}"
      interval="3600"
      duration="420"
    >
      <swiper-item
        wx:for="{{banners}}"
        wx:key="id"
        data-link-type="{{item.linkType}}"
        data-link-target="{{item.linkTarget}}"
        bindtap="handleBannerTap"
      >
        <view class="hero card">
          <image class="hero-image" src="{{item.imageUrl}}" mode="aspectFill" />
          <view class="hero-mask">
            <text class="hero-kicker">禹邻优鲜</text>
            <text class="hero-title">{{item.title}}</text>
            <text class="hero-subtitle">{{item.subtitle}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <view class="category-grid">
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="category-entry"
      data-id="{{item.id}}"
      bindtap="goCategory"
    >
      <view class="category-icon">
        <image class="category-icon-image" src="{{item.icon}}" mode="aspectFit" />
      </view>
      <text>{{item.name}}</text>
    </view>
  </view>

  <view class="section-head">
    <view>
      <text class="section-title">今日推荐</text>
      <text class="section-subtitle">门店精选，当日新鲜</text>
    </view>
    <view class="section-more">
      <text>更多</text>
      <image class="section-more-icon" src="/assets/icons/chevron-right-green.svg" mode="aspectFit" />
    </view>
  </view>

  <view class="product-grid">
    <product-card
      wx:for="{{products}}"
      wx:key="id"
      product="{{item}}"
      bind:add="handleAdd"
    />
  </view>

  <cart-add-sheet
    visible="{{sheetVisible}}"
    product="{{selectedProduct}}"
    bind:close="handleCloseSheet"
    bind:confirm="handleConfirmAdd"
  />
  <app-tabbar active="home" cart-count="{{cartCount}}" />
</view>
