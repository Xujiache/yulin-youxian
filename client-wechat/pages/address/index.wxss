.address-page {
  min-height: 100vh;
  padding: 196rpx 24rpx 144rpx;
  background: #f5f6f7;
}

.address-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 176rpx;
  padding: 88rpx 24rpx 0;
  background: #f5f6f7;
  box-shadow: 0 1rpx 0 rgba(16, 24, 21, 0.04);
}

.back,
.placeholder {
  width: 56rpx;
}

.back {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  height: 56rpx;
  z-index: 1;
}

.back-icon {
  width: 36rpx;
  height: 36rpx;
}

.title {
  position: absolute;
  left: 120rpx;
  right: 120rpx;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  color: #101815;
  font-size: 32rpx;
  font-weight: 700;
}

.address-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.empty-address {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 520rpx;
  padding: 64rpx 42rpx;
  text-align: center;
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 116rpx;
  height: 116rpx;
  margin-bottom: 28rpx;
  background: #e8f7ee;
  border-radius: 999rpx;
}

.empty-icon-image {
  width: 58rpx;
  height: 58rpx;
}

.empty-title {
  color: #101815;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 46rpx;
}

.empty-desc {
  display: block;
  max-width: 520rpx;
  margin-top: 16rpx;
  color: #5b665f;
  font-size: 26rpx;
  line-height: 38rpx;
}

.empty-add {
  min-width: 260rpx;
  margin-top: 38rpx;
}

.address-card {
  padding: 28rpx;
}

.address-card.selected {
  border-color: rgba(0, 122, 61, 0.32);
  box-shadow: 0 12rpx 32rpx rgba(0, 122, 61, 0.12);
}

.receiver {
  display: block;
  color: #101815;
  font-size: 30rpx;
  font-weight: 700;
}

.detail {
  display: block;
  margin-top: 12rpx;
  color: #5b665f;
  font-size: 26rpx;
  line-height: 38rpx;
}

.location-name {
  display: block;
  margin-top: 12rpx;
  color: #007a3d;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 36rpx;
}

.address-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #eef1ef;
}

.default {
  color: #5b665f;
  font-size: 24rpx;
}

.default.active {
  color: #007a3d;
  font-weight: 700;
}

.ops {
  display: flex;
  gap: 28rpx;
  color: #007a3d;
  font-size: 24rpx;
  font-weight: 600;
}

.add-address {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
}

.form-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.35);
}

.form-panel {
  width: 100%;
  padding: 34rpx 24rpx calc(36rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-radius: 36rpx 36rpx 0 0;
  box-shadow: 0 -16rpx 42rpx rgba(8, 34, 20, 0.12);
}

.form-title {
  margin-bottom: 24rpx;
  color: #101815;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.form-fields {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-input,
.form-textarea {
  width: 100%;
  color: #101815;
  font-size: 26rpx;
  background: #fbfdfb;
  border: 1rpx solid #e2ebe1;
  border-radius: 20rpx;
}

.location-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
  padding: 18rpx 22rpx;
  background: #f2fbf5;
  border: 1rpx solid rgba(0, 122, 61, 0.16);
  border-radius: 20rpx;
}

.location-copy {
  flex: 1;
  min-width: 0;
}

.location-label {
  display: block;
  color: #101815;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 36rpx;
}

.location-tip {
  display: block;
  margin-top: 6rpx;
  color: #5b665f;
  font-size: 23rpx;
  line-height: 32rpx;
}

.location-arrow {
  width: 30rpx;
  height: 30rpx;
  margin-left: 18rpx;
}

.form-input {
  height: 76rpx;
  padding: 0 24rpx;
  line-height: 76rpx;
}

.form-textarea {
  height: 154rpx;
  padding: 20rpx 24rpx;
  line-height: 36rpx;
}

.form-placeholder {
  color: #8b968f;
  font-size: 26rpx;
}

.default-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 56rpx;
  margin: 18rpx 0 24rpx;
  color: #5b665f;
  font-size: 26rpx;
}

.form-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.save-button {
  width: 100%;
}
