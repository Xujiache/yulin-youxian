.orders-page {
  min-height: 100vh;
  padding: 286rpx 24rpx 164rpx;
  background: #f5f6f7;
}

.tabs-wrap {
  position: fixed;
  top: 180rpx;
  left: 0;
  right: 0;
  z-index: 45;
  padding: 10rpx 14rpx 16rpx;
  background: #f5f6f7;
}

.status-tabs {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 4rpx;
  height: 78rpx;
  padding: 8rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 122, 61, 0.08);
  border-radius: var(--radius-panel);
  box-shadow: 0 10rpx 28rpx rgba(8, 34, 20, 0.06);
}

.status-tab {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 62rpx;
  padding: 0 2rpx;
  overflow: hidden;
  color: #5b665f;
  font-size: 21rpx;
  font-weight: 600;
  border-radius: 16rpx;
  white-space: nowrap;
}

.status-tab.active {
  color: #007a3d;
  font-weight: 800;
  background: #e8f7ee;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.empty-orders {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 560rpx;
  padding: 48rpx 34rpx;
  text-align: center;
  background: #ffffff;
  border-radius: var(--radius-card);
  box-shadow: 0 10rpx 28rpx rgba(8, 34, 20, 0.05);
}

.empty-paper {
  width: 260rpx;
  padding: 24rpx 22rpx 22rpx;
  background: #f8fbf9;
  border: 2rpx solid #e2eee7;
  border-radius: var(--radius-card);
}

.paper-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #007a3d;
  font-size: 22rpx;
  font-weight: 900;
}

.paper-dot {
  width: 16rpx;
  height: 16rpx;
  background: #008a45;
  border-radius: var(--radius-pill);
}

.paper-line {
  height: 14rpx;
  margin-top: 16rpx;
  background: #e5f2ea;
  border-radius: var(--radius-pill);
}

.paper-line.strong {
  width: 100%;
  background: #cfe8d8;
}

.paper-line.short {
  width: 66%;
}

.paper-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 22rpx;
  color: #7b8781;
  font-size: 20rpx;
}

.empty-title {
  margin-top: 30rpx;
  color: #101815;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 46rpx;
}

.empty-desc {
  display: block;
  max-width: 520rpx;
  margin-top: 14rpx;
  color: #5b665f;
  font-size: 25rpx;
  line-height: 38rpx;
}

.empty-action {
  min-width: 220rpx;
  margin-top: 34rpx;
}

.order-card {
  padding: 26rpx;
}

.order-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  color: #5b665f;
  font-size: 24rpx;
  line-height: 34rpx;
}

.order-status {
  flex-shrink: 0;
  color: #007a3d;
  font-weight: 800;
}

.refund-notice {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  color: #9a4a00;
  font-size: 24rpx;
  line-height: 34rpx;
  background: #fff7ed;
  border: 1rpx solid #ffd8ad;
  border-radius: 18rpx;
}

.order-body {
  display: flex;
  gap: 22rpx;
  margin-top: 24rpx;
}

.thumbs {
  display: flex;
  flex-shrink: 0;
  width: 192rpx;
  overflow: hidden;
}

.thumb {
  width: 82rpx;
  height: 82rpx;
  margin-right: -18rpx;
  background: #eef3ed;
  border: 4rpx solid #ffffff;
  border-radius: 18rpx;
}

.order-info {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
  color: #5b665f;
  font-size: 24rpx;
  line-height: 34rpx;
}

.order-total {
  color: #101815;
  font-size: 28rpx;
  font-weight: 800;
}

.order-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eef1ef;
}

.small {
  width: auto;
  min-height: 60rpx;
  padding: 0 30rpx;
  font-size: 24rpx;
}

.order-action-button {
  flex: 0 0 calc((100% - 16rpx) / 2);
  width: calc((100% - 16rpx) / 2);
  max-width: calc((100% - 16rpx) / 2);
  min-width: 0;
  height: 60rpx;
  min-height: 60rpx;
  box-sizing: border-box;
  margin: 0;
  padding: 0 18rpx;
  overflow: hidden;
  line-height: 60rpx;
  font-size: 24rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-action-button.primary {
  box-shadow: 0 10rpx 22rpx rgba(0, 122, 61, 0.14);
}

.order-action-button.secondary {
  background: #ffffff;
}
