<view class="cart-page {{glassMode ? 'glass-mode' : ''}}">
  <skeleton wx:if="{{loading}}" type="list" has-tabbar="{{true}}" />
  <view class="page-header">
    <text class="page-title">禹邻优鲜</text>
    <text class="clear {{items.length ? '' : 'disabled'}}" bindtap="handleClearSelected">清空</text>
  </view>

  <view wx:if="{{!items.length && !loading}}" class="cart-empty">
    <view class="empty-line">
      <image class="empty-line-icon" src="/assets/icons/tab-cart-active.svg" mode="aspectFit" />
      <view class="empty-copy">
        <text class="empty-title">购物车是空的</text>
        <text class="empty-desc">先看看今天到店的新鲜好物</text>
      </view>
      <button class="empty-link" bindtap="goHome">去逛逛</button>
    </view>

    <view wx:if="{{recommendedProducts.length}}" class="recommend-section">
      <view class="recommend-head">
        <text class="recommend-title">为你推荐</text>
        <text class="recommend-subtitle">门店精选</text>
      </view>
      <view class="recommend-grid">
        <product-card
          wx:for="{{recommendedProducts}}"
          wx:key="id"
          product="{{item}}"
          bind:add="handleAddRecommended"
        />
      </view>
    </view>
  </view>

  <view wx:else class="cart-list">
    <view wx:for="{{items}}" wx:key="id" class="cart-item card">
      <view class="cart-main">
        <view class="check {{item.selected ? 'checked' : ''}}" data-id="{{item.id}}" bindtap="handleToggle">
          <image wx:if="{{item.selected}}" class="check-icon" src="/assets/icons/check-white.svg" mode="aspectFit" />
        </view>
        <image class="item-image" src="{{item.image}}" mode="aspectFill" lazy-load="{{true}}" />
        <view class="item-info">
          <text class="item-name">{{item.name}}</text>
          <text class="item-subtitle">{{item.subtitle}}</text>
          <view class="item-bottom">
            <text class="item-price">￥{{item.amountText}}</text>
            <view class="cart-stepper-shell">
              <quantity-stepper
                data-id="{{item.id}}"
                value="{{item.quantity}}"
                min="{{item.minPurchaseQty || 1}}"
                max="{{item.stockQty || 9999}}"
                step="{{item.stepQty || 1}}"
                unit="{{item.saleUnit || ''}}"
                bind:change="handleQuantityChange"
              />
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{items.length}}" class="checkout-bar">
    <view class="checkout-meta">
      <view class="select-group {{items.length ? '' : 'muted'}}">
        <view class="check {{items.length ? 'checked' : ''}}">
          <image class="check-icon" src="/assets/icons/check-white.svg" mode="aspectFit" />
        </view>
        <text class="select-all">全选</text>
      </view>
      <view class="total">
        <text class="total-label">合计：</text>
        <text class="total-price">￥{{totalText}}</text>
      </view>
    </view>
    <button class="primary-button checkout-button {{selectedCount ? '' : 'disabled'}}" disabled="{{!selectedCount}}" bindtap="handleCheckout">
      <text>去结算</text>
      <image class="checkout-arrow" src="/assets/icons/chevron-right-white.svg" mode="aspectFit" />
    </button>
  </view>

  <app-tabbar active="cart" cart-count="{{items.length}}" />
</view>
