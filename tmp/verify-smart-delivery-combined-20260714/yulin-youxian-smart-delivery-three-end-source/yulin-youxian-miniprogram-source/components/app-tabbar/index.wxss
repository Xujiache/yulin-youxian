.tabbar {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 108rpx;
  padding: 10rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid rgba(0, 122, 61, 0.1);
  border-radius: 999rpx;
  box-shadow: 0 20rpx 48rpx rgba(18, 44, 29, 0.14);
}

.tab-item {
  position: relative;
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  height: 88rpx;
  color: #56645d;
  font-size: 22rpx;
  border-radius: 999rpx;
}

.tab-item.active {
  color: #007a3d;
  font-weight: 700;
  background: #e8f7ee;
}

.icon-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
}

.tab-icon {
  width: 50rpx;
  height: 50rpx;
}

.tab-text {
  font-size: 22rpx;
  line-height: 26rpx;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -14rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 7rpx;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
  background: #c92222;
  border-radius: 999rpx;
}

.tabbar.glass-mode {
  background: var(--surface);
  border-color: var(--surface-line);
  box-shadow: var(--shadow-float);
  backdrop-filter: blur(var(--glass-blur)) saturate(145%);
  -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(145%);
}

.tabbar.glass-mode .tab-item.active {
  background: var(--brand-soft);
}
