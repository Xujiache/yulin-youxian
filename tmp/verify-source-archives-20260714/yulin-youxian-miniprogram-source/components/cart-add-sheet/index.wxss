.sheet-root {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 100;
}

.mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.38);
}

.sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx 28rpx calc(34rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-radius: 42rpx 42rpx 0 0;
  box-shadow: 0 -18rpx 48rpx rgba(11, 30, 20, 0.16);
}

.sheet-header {
  position: relative;
  display: flex;
  gap: 22rpx;
  padding-right: 82rpx;
}

.sheet-image {
  width: 150rpx;
  height: 150rpx;
  background: #eef3ef;
  border-radius: 22rpx;
}

.sheet-info {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.sheet-name {
  color: #101815;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.sheet-subtitle {
  margin-top: 8rpx;
  color: #626d66;
  font-size: 24rpx;
  line-height: 32rpx;
}

.sheet-price {
  margin-top: 10rpx;
  color: #007a3d;
  font-size: 32rpx;
  font-weight: 800;
}

.close {
  position: absolute;
  top: -6rpx;
  right: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx !important;
  min-width: 56rpx;
  max-width: 56rpx;
  height: 56rpx;
  flex: 0 0 56rpx;
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
  box-sizing: border-box;
}

.close::after {
  border: 0;
}

.close-icon {
  width: 28rpx;
  height: 28rpx;
}

.field-row {
  display: block;
  margin-top: 38rpx;
}

.field-title {
  display: block;
  color: #101815;
  font-size: 30rpx;
  font-weight: 600;
}

.field-tip {
  display: block;
  margin-top: 8rpx;
  color: #626d66;
  font-size: 22rpx;
  line-height: 30rpx;
}

.sheet-stepper-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 24rpx;
}

.sheet-stepper-control {
  width: 292rpx;
  flex: 0 0 292rpx;
}

.summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 36rpx 0 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #edf0ee;
}

.summary-label {
  color: #626d66;
  font-size: 26rpx;
}

.summary-price {
  color: #007a3d;
  font-size: 46rpx;
  font-weight: 800;
}

.confirm {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  margin: 0;
  padding: 0;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 88rpx;
  background: linear-gradient(135deg, #008f55 0%, #006d42 100%);
  border-radius: 999rpx;
  box-shadow: 0 14rpx 30rpx rgba(0, 109, 66, 0.22);
}

.confirm::after {
  border: 0;
}

.sheet.glass-mode {
  background: rgba(246, 253, 249, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  box-shadow: var(--shadow-float);
  backdrop-filter: blur(var(--glass-blur)) saturate(145%);
  -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(145%);
}

.sheet.glass-mode .sheet-subtitle,
.sheet.glass-mode .field-tip,
.sheet.glass-mode .summary-label {
  color: #52675b;
}

.sheet.glass-mode .summary {
  border-top-color: rgba(95, 143, 111, 0.24);
}

.sheet.glass-mode .close {
  top: -6rpx;
  background: transparent;
  box-shadow: none;
}

.sheet.glass-mode .confirm {
  background: linear-gradient(135deg, #00945a 0%, #006b40 100%);
  box-shadow: 0 16rpx 34rpx rgba(0, 109, 66, 0.28), inset 0 1rpx 0 rgba(255, 255, 255, 0.25);
}
