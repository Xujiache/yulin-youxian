.skeleton-layer {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 120;
  box-sizing: border-box;
  padding: calc(44rpx + env(safe-area-inset-top)) 24rpx 32rpx;
  background: #f6f8f7;
  overflow: hidden;
}

.skeleton-layer.has-tabbar {
  padding-bottom: 166rpx;
}

.skeleton-header,
.sk-section-head,
.sk-row,
.sk-category-row,
.sk-tabbar {
  display: flex;
  align-items: center;
}

.skeleton-header,
.sk-section-head {
  justify-content: space-between;
}

.skeleton-header {
  height: 64rpx;
  margin-bottom: 22rpx;
}

.sk-line,
.sk-pill,
.sk-search,
.sk-hero,
.sk-image,
.sk-panel,
.sk-circle,
.sk-tab,
.sk-stepper,
.sk-input,
.sk-button,
.sk-chip,
.sk-rank,
.sk-detail-hero,
.sk-profile-hero {
  position: relative;
  overflow: hidden;
  background: #e9f0ec;
}

.sk-line::after,
.sk-pill::after,
.sk-search::after,
.sk-hero::after,
.sk-image::after,
.sk-panel::after,
.sk-circle::after,
.sk-tab::after,
.sk-stepper::after,
.sk-input::after,
.sk-button::after,
.sk-chip::after,
.sk-rank::after,
.sk-detail-hero::after,
.sk-profile-hero::after {
  content: "";
  position: absolute;
  top: 0;
  bottom: 0;
  left: -45%;
  width: 45%;
  background: linear-gradient(90deg, rgba(255,255,255,0), rgba(255,255,255,.74), rgba(255,255,255,0));
  animation: skeleton-shimmer 1.25s ease-in-out infinite;
}

@keyframes skeleton-shimmer {
  0% { transform: translateX(0); }
  100% { transform: translateX(320%); }
}

.sk-line {
  height: 24rpx;
  border-radius: 999rpx;
}

.sk-line.title { width: 168rpx; height: 34rpx; }
.sk-line.large { width: 220rpx; height: 30rpx; }
.sk-line.medium { width: 154rpx; }
.sk-line.small { width: 92rpx; height: 20rpx; }
.sk-line.tiny { width: 56rpx; height: 16rpx; }
.sk-line.full { width: 100%; height: 22rpx; }
.sk-line.price { width: 128rpx; height: 36rpx; background: #d8eadf; }

.sk-pill {
  width: 92rpx;
  height: 36rpx;
  border-radius: 999rpx;
}

.sk-pill.mini {
  width: 72rpx;
}

.sk-search {
  height: 76rpx;
  border-radius: 999rpx;
  margin-bottom: 20rpx;
}

.sk-hero {
  height: 280rpx;
  border-radius: 22rpx;
  margin-bottom: 22rpx;
}

.sk-hero.compact {
  height: 240rpx;
}

.sk-category-row {
  justify-content: space-between;
  margin: 4rpx 0 26rpx;
}

.sk-category {
  width: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.sk-circle {
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
}

.small-circle {
  width: 44rpx;
  height: 44rpx;
  margin-right: 18rpx;
}

.sk-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 18rpx;
}

.sk-card,
.sk-panel {
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(0, 80, 44, .05);
}

.sk-card {
  padding: 16rpx;
}

.sk-image {
  width: 100%;
  height: 210rpx;
  border-radius: 18rpx;
  margin-bottom: 18rpx;
}

.sk-category-layout {
  display: flex;
  gap: 18rpx;
  height: 74vh;
}

.sk-sidebar {
  width: 150rpx;
}

.sk-tab {
  height: 76rpx;
  border-radius: 18rpx;
  margin-bottom: 18rpx;
}

.sk-product-area {
  flex: 1;
}

.sk-detail-hero {
  height: 430rpx;
  border-radius: 0 0 28rpx 28rpx;
  margin: -18rpx -24rpx 22rpx;
}

.sk-panel {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.sk-panel .sk-line + .sk-line {
  margin-top: 18rpx;
}

.sk-stepper {
  height: 60rpx;
  border-radius: 999rpx;
  margin-top: 24rpx;
}

.sk-profile-hero {
  height: 260rpx;
  border-radius: 0 0 26rpx 26rpx;
  margin: -18rpx -24rpx 22rpx;
  padding: 122rpx 32rpx 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.sk-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: #e3eee7;
}

.sk-avatar.center {
  margin: 0 auto 28rpx;
}

.sk-profile-lines {
  margin-left: 22rpx;
  flex: 1;
}

.sk-input {
  height: 76rpx;
  border-radius: 18rpx;
  margin-bottom: 20rpx;
}

.sk-button {
  height: 86rpx;
  border-radius: 999rpx;
  background: #d5eadf;
}

.sk-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.sk-chip {
  width: 116rpx;
  height: 56rpx;
  border-radius: 999rpx;
}

.sk-rank-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.sk-rank {
  height: 92rpx;
  border-radius: 18rpx;
}

.list-search {
  height: 64rpx;
}

.list-panel {
  padding: 20rpx;
}

.sk-image.thumb {
  width: 132rpx;
  height: 132rpx;
  flex: none;
  margin: 0 20rpx 0 0;
}

.sk-list-lines {
  flex: 1;
}

.sk-tabbar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  height: 96rpx;
  justify-content: space-around;
  border-radius: 999rpx;
  background: #fff;
  box-shadow: 0 10rpx 34rpx rgba(0, 80, 44, .1);
}

.sk-tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.tabbar-dot {
  width: 34rpx;
  height: 34rpx;
}

.skeleton-layer.glass-mode {
  background: rgba(229, 241, 233, 0.72);
  backdrop-filter: blur(var(--glass-blur)) saturate(130%);
  -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(130%);
}

.skeleton-layer.glass-mode .sk-line,
.skeleton-layer.glass-mode .sk-pill,
.skeleton-layer.glass-mode .sk-search,
.skeleton-layer.glass-mode .sk-hero,
.skeleton-layer.glass-mode .sk-image,
.skeleton-layer.glass-mode .sk-panel,
.skeleton-layer.glass-mode .sk-card,
.skeleton-layer.glass-mode .sk-tabbar {
  background: rgba(255, 255, 255, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.68);
}
