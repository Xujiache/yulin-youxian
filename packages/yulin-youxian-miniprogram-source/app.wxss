page {
  --radius-card: 20rpx;
  --radius-panel: 20rpx;
  --radius-pill: 999rpx;
  min-height: 100vh;
  background: #f5f6f7;
  color: #101815;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1;
  background: transparent;
  border: 0;
  border-radius: 0;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 196rpx 24rpx 164rpx;
}

.page-title {
  color: #007a3d;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 46rpx;
  letter-spacing: 0;
}

.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 176rpx;
  padding: 88rpx 176rpx 0 28rpx;
  background: #f5f6f7;
  box-shadow: 0 1rpx 0 rgba(16, 24, 21, 0.04);
}

.card {
  background: #ffffff;
  border: 1rpx solid rgba(0, 122, 61, 0.04);
  border-radius: var(--radius-card);
  box-shadow: 0 10rpx 30rpx rgba(8, 34, 20, 0.05);
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 36rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  background: #007a3d;
  border-radius: 999rpx;
  box-shadow: 0 16rpx 32rpx rgba(0, 122, 61, 0.22);
}

.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 0 28rpx;
  color: #007a3d;
  font-size: 28rpx;
  font-weight: 500;
  border: 1rpx solid #007a3d;
  border-radius: 999rpx;
}

.muted {
  color: #5b665f;
}

.price {
  color: #007a3d;
  font-weight: 800;
}
