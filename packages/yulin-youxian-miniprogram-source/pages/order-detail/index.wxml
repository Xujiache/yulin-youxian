<view class="order-detail-page">
  <skeleton wx:if="{{loading}}" type="detail" />
  <view class="detail-header">
    <navigator class="back" open-type="navigateBack">
      <image class="back-icon" src="/assets/icons/back-green.svg" mode="aspectFit" />
    </navigator>
    <text class="title">订单详情</text>
    <view class="placeholder"></view>
  </view>

  <view class="status-card card">
    <text class="status">{{statusText}}</text>
    <text class="status-desc">订单编号：{{orderNo}}</text>
  </view>

  <view wx:if="{{refundNotice}}" class="refund-notice card">
    <text>{{refundNotice}}</text>
  </view>

  <view class="card">
    <text class="module-title">收货信息</text>
    <text class="line">{{address.name}} {{address.phone}}</text>
    <text class="line muted">{{address.detail}}</text>
    <text class="line muted">期望送达时间：{{deliverySlotText}}</text>
  </view>

  <view class="card">
    <text class="module-title">商品明细</text>
    <view wx:for="{{items}}" wx:key="id" class="goods-item">
      <image class="goods-image" src="{{item.image}}" mode="aspectFill" />
      <view class="goods-info">
        <text class="goods-name">{{item.name || item.productName}}</text>
        <text class="goods-spec">{{item.quantity}}{{item.saleUnit}} x1</text>
      </view>
      <text class="goods-price">￥{{item.amountText}}</text>
    </view>
  </view>

  <view class="card">
    <view class="amount-row">
      <text>商品总额</text>
      <text>￥{{productAmountText}}</text>
    </view>
    <view class="amount-row">
      <text>配送费</text>
      <text>￥{{deliveryFeeText}}</text>
    </view>
    <view class="amount-row">
      <text>包装费</text>
      <text>￥{{packageFeeText}}</text>
    </view>
    <view wx:if="{{hasRefundedAmount}}" class="amount-row">
      <text>已退款</text>
      <text>-￥{{refundedText}}</text>
    </view>
    <view class="amount-row strong">
      <text>实付款</text>
      <text>￥{{payableText}}</text>
    </view>
  </view>

  <view class="detail-actions">
    <button class="ghost-button detail-action-button" bindtap="handleService">联系客服</button>
    <button class="primary-button detail-action-button" bindtap="handleRefund">申请退款</button>
  </view>
</view>
