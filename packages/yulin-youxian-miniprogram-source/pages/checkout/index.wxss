.checkout-page {
  min-height: 100vh;
  padding: 196rpx 22rpx 150rpx;
  background: #f5f6f7;
}

.checkout-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 176rpx;
  padding: 88rpx 24rpx 0;
  background: #f5f6f7;
  box-shadow: 0 1rpx 0 rgba(16, 24, 21, 0.04);
}

.back,
.placeholder {
  width: 56rpx;
}

.back {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  height: 56rpx;
  z-index: 1;
}

.back-icon {
  width: 36rpx;
  height: 36rpx;
}

.title {
  position: absolute;
  left: 120rpx;
  right: 120rpx;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  color: #101815;
  font-size: 32rpx;
  font-weight: 700;
}

.card {
  margin-bottom: 22rpx;
  padding: 26rpx;
  border-radius: 24rpx;
}

.module-title {
  display: block;
  color: #101815;
  font-size: 32rpx;
  font-weight: 700;
}

.checkout-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 420rpx;
  padding: 58rpx 36rpx;
  text-align: center;
}

.error-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
  background: #e8f7ee;
  border-radius: 999rpx;
}

.error-title {
  color: #101815;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 44rpx;
}

.error-desc {
  display: block;
  margin-top: 14rpx;
  color: #66736b;
  font-size: 26rpx;
  line-height: 38rpx;
}

.error-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  width: 100%;
  margin-top: 36rpx;
}

.error-button {
  width: 100%;
}

.address {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 116rpx;
}

.address-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  background: #dff3e7;
  border-radius: 999rpx;
}

.location-icon {
  width: 36rpx;
  height: 36rpx;
}

.address-info {
  flex: 1;
  min-width: 0;
}

.chevron {
  width: 34rpx;
  height: 34rpx;
}

.receiver {
  display: block;
  color: #101815;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 42rpx;
}

.address-text {
  display: block;
  margin-top: 8rpx;
  color: #5b665f;
  font-size: 26rpx;
  line-height: 36rpx;
}

.slot-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.slot-title-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.slot-icon {
  width: 34rpx;
  height: 34rpx;
}

.slot-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #718078;
  font-size: 22rpx;
  line-height: 30rpx;
}

.slot-badge {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  color: #007a3d;
  font-size: 22rpx;
  font-weight: 700;
  background: #e8f7ee;
  border-radius: 999rpx;
}

.slot-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.slot {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 16rpx 20rpx;
  overflow: hidden;
  color: #4f5d55;
  font-size: 24rpx;
  font-weight: 600;
  background: linear-gradient(180deg, #ffffff 0%, #f7faf8 100%);
  border: 1rpx solid #d9e7dd;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 18rpx rgba(8, 34, 20, 0.04);
}

.slot.active {
  color: #ffffff;
  background: linear-gradient(135deg, #007a3d 0%, #1daf59 100%);
  border-color: #007a3d;
  box-shadow: 0 14rpx 28rpx rgba(0, 122, 61, 0.2);
}

.slot-label {
  position: relative;
  z-index: 1;
}

.slot-check {
  position: absolute;
  right: 12rpx;
  bottom: 10rpx;
  display: none;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  color: #007a3d;
  font-size: 18rpx;
  font-weight: 800;
  background: #ffffff;
  border-radius: 999rpx;
}

.slot.active .slot-check {
  display: flex;
}

.fee-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
  padding: 22rpx 26rpx;
  color: #007a3d;
  background: linear-gradient(135deg, #e8f7ee 0%, #ffffff 100%);
  border: 1rpx solid rgba(0, 122, 61, 0.12);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(8, 34, 20, 0.05);
}

.fee-banner-title {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 800;
}

.fee-banner-desc {
  flex: 1;
  color: #4f5d55;
  font-size: 24rpx;
  line-height: 34rpx;
  text-align: right;
}

.goods-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf1ef;
}

.goods-item:last-child {
  border-bottom: 0;
}

.goods-image {
  width: 116rpx;
  height: 116rpx;
  background: #eef3ef;
  border-radius: 16rpx;
}

.goods-info {
  flex: 1;
  min-width: 0;
}

.goods-name {
  display: block;
  color: #101815;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 38rpx;
}

.goods-spec {
  display: block;
  margin-top: 8rpx;
  color: #627068;
  font-size: 24rpx;
}

.goods-price {
  color: #101815;
  font-size: 28rpx;
  font-weight: 700;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  color: #4f5d55;
  font-size: 26rpx;
}

.remark-input {
  width: 100%;
  height: 128rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  color: #101815;
  font-size: 26rpx;
  background: #f7f8f8;
  border: 1rpx solid #d3ded7;
  border-radius: 16rpx;
}

.pay-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 70;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 24rpx 34rpx;
  background: #ffffff;
  box-shadow: 0 -10rpx 32rpx rgba(10, 34, 22, 0.1);
}

.pay-total {
  flex: 1;
  color: #4f5d55;
  font-size: 24rpx;
}

.pay-price {
  color: #007a3d;
  font-size: 48rpx;
  font-weight: 800;
}

.pay-button {
  min-width: 246rpx;
  min-height: 88rpx;
}

.pay-button.disabled {
  color: rgba(255, 255, 255, 0.72);
  background: #9fb3a8;
  box-shadow: none;
}
